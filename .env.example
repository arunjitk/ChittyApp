# ─────────────────────────────────────────────────────────────────────────────
# ChittyLoanApp — Production Environment Variables
#
# Copy this file to .env and fill in real values:
#   cp .env.example .env
#   nano .env
#
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
DB_NAME=chitty_loan_app
DB_USER=chitty_user
DB_PASSWORD=CHANGE_THIS_USE_A_STRONG_PASSWORD

# ── App ───────────────────────────────────────────────────────────────────────
# Generate a strong random secret: openssl rand -hex 64
JWT_SECRET=CHANGE_THIS_TO_A_VERY_LONG_RANDOM_STRING_AT_LEAST_64_CHARACTERS

# Your production domain (no trailing slash)
FRONTEND_URL=https://yourdomain.com

# The URL the React app uses to call the API (baked into the JS bundle at build time)
REACT_APP_API_URL=https://yourdomain.com/api
